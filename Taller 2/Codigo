import numpy as np
from scipy.optimize import linprog

# Queremos maximizar 180x1 + 220x2. 
# Como linprog minimiza, hay qie usar valores negativos.
c = [-180, -220]

# Coeficientes de las Restricciones (Lado izquierdo: Matriz A)
# Las filas son Compuesto A, B y C respectivamente.
A = [
    [3, 4], # 3x1 + 4x2 (Compuesto A)
    [2, 1], # 2x1 + 1x2 (Compuesto B)
    [5, 3]  # 5x1 + 3x2 (Compuesto C)
]

# Disponibilidad (Lado derecho: Vector b)
b = [120, 80, 150]

# Límites de las variables (No negatividad: x >= 0)
x_bounds = (0, None)

# Resolver el problema
# Usamos el método 'highs'
res = linprog(c, A_ub=A, b_ub=b, bounds=[x_bounds, x_bounds], method='highs')

# Imprimir los resultados
print("-" * 30)
print("Punto 1. Mezcla de fertilizantes.")
print("-" * 30)

if res.success:
    print(f"Cantidad de F1 (x1) a producir: {res.x[0]:.2f} toneladas")
    print(f"Cantidad de F2 (x2) a producir: {res.x[1]:.2f} toneladas")
    print("-" * 30)

