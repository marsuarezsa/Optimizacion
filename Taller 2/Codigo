PUNTO 4.

import numpy as np
from scipy.optimize import fsolve

print("-" * 30)
print("Punto 4. Modelo logistico de pesca.")
print("-" * 30)

# Parámetros
r = 0.4
K = 1000
H = 80
P0 = 400

def modelo_pesca(Pn):
    # Ecuación: Pn + r * Pn * (1 - Pn/K) - H
    return Pn + r * Pn * (1 - Pn/K) - H

P1 = modelo_pesca(P0)
P2 = modelo_pesca(P1)

print("-" * 40)
print(f"Población al final del Año 1: {P1:.2f} peces")
print(f"Población al final del Año 2: {P2:.2f} peces")
print("-" * 40)

# Puntos de Equilibrio
# r * P * (1 - P/K) - H = 0
def ecuacion_equilibrio(P):
    return r * P * (1 - P/K) - H

# fsolve de scipy para encontrar las raíces de la ecuación
# dos "estimaciones" iniciales porque es una ecuación cuadrática
equilibrio_alto = fsolve(ecuacion_equilibrio, 800)[0] 
equilibrio_bajo = fsolve(ecuacion_equilibrio, 200)[0]

print(f"Punto de equilibrio (Estable)):   {equilibrio_alto:.2f} peces")
print(f"Punto de equilibrio (Inestable): {equilibrio_bajo:.2f} peces")
print("-" * 40)

if P0 > equilibrio_bajo:
    print("Interpretación: La población sobrevivirá y tenderá al equilibrio estable.")
else:
    print("Interpretación: La población está por debajo del umbral y se extinguirá.")
