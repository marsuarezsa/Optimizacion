PUNTO 3.

import numpy as np
from scipy.integrate import solve_ivp

print("-" * 30)
print("Punto 3. Epidemia en una ciudad.")
print("-" * 30)

# Parámetros
beta = 0.00003
gamma = 0.1
P = 10000

# Modelo (EDO)
def modelo_sis(t, I):
    dIdt = beta * (P - I) * I - gamma * I
    return dIdt

# Condición inicial 
I0 = [50] 
t_i = 0
t_f = 150 
t_eval = np.linspace(t_i, t_f, 100) 

# Resolver
res = solve_ivp(modelo_sis, [t_i, t_f], I0, t_eval=t_eval) 

# Extraer los datos de 'res'
t = res.t
I = res.y[0] # Es la primera fila de resultados

# Imprimir valores
print(f"Infectados iniciales:   {I0[0]}")
print(f"Valor máximo alcanzado: {max(I):.1f} personas (día {t[np.argmax(I)]:.1f})")
print(f"Valor al final del periodo: {I[-1]:.1f} personas")
print(f"Equilibrio teórico I*:  {P - gamma/beta:.1f} personas")


